rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid 
          && data.email is string && data.email == request.auth.token.email
          && (data.get('displayName', '') is string && data.get('displayName', '').size() < 256)
          && (data.get('completedCourses', []) is list && data.get('completedCourses', []).size() <= 100);
    }

    // --- Collection Matches ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && (
          // Action: Mark Course Complete
          incoming().diff(existing()).affectedKeys().hasOnly(['completedCourses']) ||
          // Action: Update Profile
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'keySkills', 'experience', 'education'])
        );
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
    }

    match /enrollments/{enrollmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid 
        && incoming().diff(existing()).affectedKeys().hasOnly(['progress', 'status']);
    }

    match /certificates/{certId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
    }
  }
}
